{
  "name": "multi-agent-threejs-site",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "uv run python scene_agents.py",
    "start:web": "uv run python multi_agent_site.py",
    "preview": "node serve_static.js",
    "start:python": "python scene_agents.py",
    "check:tools": "uv run python check_tools.py",
    "qa": "node qa_check.js index.html smoke-scene",
    "visual:qa": "node tools/visual_qa.js",
    "visual:match": "node tools/reference_matcher.js",
    "agent:status": "node tools/agent_status.js",
    "memory": "node tools/agent_memory.js",
    "memory:db": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_memory_db.py",
    "agent:context": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_context.py",
    "agent:log": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_log.py",
    "agent:checkpoint": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_checkpoint.py",
    "agent:evals": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_evals.py",
    "agent:meta": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_meta.py",
    "agent:goal": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/agent_goal.py",
    "tradelab:incubate": "node tools/tradelab_incubate_once.js",
    "tradelab:gate": "node tools/tradelab_real_money_gate.js",
    "tradelab:report": "node tools/tradelab_incubation_report.js",
    "tradelab:cycle": "node tools/tradelab_review_cycle.js",
    "tradelab:watch": "node tools/tradelab_watch.js",
    "tradelab:watch:forever": "node tools/tradelab_watch.js --forever --minutes=60",
    "tradelab:watch:daemon": "bash tools/tradelab_watch_forever.sh",
    "tradelab:safety": "node tools/tradelab_safety_audit.js",
    "tradelab:doctor": "node tools/tradelab_doctor.js",
    "tradelab:discover": "node tools/tradelab_daily_discovery.js",
    "tradelab:news": "node tools/tradelab_news_impact.js",
    "tradelab:dependencies": "node tools/tradelab_news_dependencies.js",
    "tradelab:drawdown": "node tools/tradelab_drawdown_diagnostics.js",
    "tradelab:quarantine": "node tools/tradelab_quarantine.js",
    "tradelab:unquarantine": "node tools/tradelab_unquarantine.js",
    "tradelab:scout": "node tools/tradelab_replacement_scout.js",
    "tradelab:scoreboard": "node tools/tradelab_scoreboard.js",
    "tradelab:network": "node tools/tradelab_network_health.js",
    "tradelab:lifecycle": "node tools/tradelab_lifecycle.js",
    "tradelab:recovery:promote": "node tools/tradelab_promote_recovery.js",
    "tradelab:risk": "node -e \"console.log(JSON.stringify(require('./tools/tradelab_risk_controls').portfolioKillSwitch(), null, 2))\"",
    "tradelab:risk:manager": "node tools/tradelab_risk_manager.js",
    "tradelab:dashboard": "node tools/tradelab_dashboard.js",
    "tradelab:paper:trader": "node tools/tradelab_paper_trader.js",
    "tradelab:live": "node tools/tradelab_live_executor.js",
    "tradelab:live:trades": "node -e \"console.log(JSON.stringify(require('./tools/tradelab_live_executor').loadTrades(), null, 2))\"",
    "tradelab:live:pnl": "node -e \"console.log(JSON.stringify(require('./tools/tradelab_live_executor').loadDailyPnl(), null, 2))\"",
    "tradelab:live:gate": "node tools/tradelab_real_money_gate.js",
    "tradelab:live:loop": "node tools/tradelab_live_loop.js paper",
    "tradelab:live:loop:live": "node tools/tradelab_live_loop.js live",
    "tradelab:live:loop:check": "node tools/tradelab_live_loop.js --once",
    "tradelab:live:force": "node tools/tradelab_force_ready.js",
    "tradelab:live:softgate": "node tools/tradelab_soft_gate.js",
    "tradelab:telegram": "node tools/tradelab_telegram_bot.js",
    "tradelab:strategies:new": "node tools/tradelab_new_strategies.js",
    "tradelab:walkforward": "node tools/tradelab_walk_forward.js",
    "tradelab:ml": "node tools/tradelab_ml_signals.js",
    "tradelab:portfolio:optimize": "node tools/tradelab_portfolio_optimizer.js",
    "tradelab:telemetry": "node tools/tradelab_telemetry.js",
    "tradelab:telemetry:dashboard": "node tools/tradelab_telemetry.js --dashboard",
    "scene:status": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/scene_status.py",
    "scene:attempt": "set UV_CACHE_DIR=.uv-cache&& uv run python tools/scene_attempt.py",
    "hf:infer": "python tools/hf_inference.py"
  },
  "dependencies": {
    "ccxt": "^4.5.61",
    "dotenv": "^17.4.2",
    "puppeteer": "^22.15.0",
    "three": "^0.164.1"
  },
  "devDependencies": {
    "sharp": "^0.35.1",
    "typescript": "^5.5.4"
  }
}
